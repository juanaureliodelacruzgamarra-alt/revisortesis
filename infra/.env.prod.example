# =============================================================================
# KIMY production environment variables.
# Copy this file to infra/.env.prod and fill in the real values.
# NEVER commit .env.prod. .gitignore already excludes it.
#
# Secret generation cheatsheet:
#   JWT_SECRET:        openssl rand -base64 48
#   ENCRYPTION_KEY:    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   POSTGRES_PASSWORD: openssl rand -base64 32
# =============================================================================

# ----- Image tagging (used by docker-compose --pull / image tag) -----
IMAGE_TAG=latest

# ----- Postgres (internal-only, never exposed via host port) -----
POSTGRES_USER=kimy
POSTGRES_PASSWORD=CHANGE_ME_USE_OPENSSL_RAND
POSTGRES_DB=kimy

# ----- API security -----
JWT_SECRET=CHANGE_ME_AT_LEAST_32_BYTES_USE_OPENSSL_RAND_BASE64_48
ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY_44_CHARS_URL_SAFE_BASE64

# ----- CORS (web origin behind reverse proxy) -----
# JSON array as a single line — be exact with quotes.
CORS_ORIGINS=["https://kimy.example.edu.pe"]

# ----- AI providers (optional — stub used if absent) -----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ----- ORCID (set ORCID_SANDBOX=false for production) -----
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=https://kimy.example.edu.pe/orcid/callback
ORCID_SANDBOX=false

# ----- CrossRef (polite pool — put a real reachable email) -----
CROSSREF_USER_AGENT=KIMY/1.0 (mailto:registrar@example.edu.pe)

# ----- API runtime tuning -----
UVICORN_WORKERS=4

# ----- Web public env -----
# Must be reachable from the user's browser, not from inside the docker net.
NEXT_PUBLIC_API_URL=https://api.kimy.example.edu.pe
