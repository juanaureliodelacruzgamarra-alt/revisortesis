ENVIRONMENT=development
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://kimy:kimy@localhost:5433/kimy

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET=change-me-in-prod
ENCRYPTION_KEY=change-me-in-prod-32-bytes-base64-fernet=

# AI providers — Google Gemini is the primary backend.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Legacy / fallback providers (optional, leave empty if not used)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ORCID OAuth
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=http://localhost:3000/orcid/callback

# CrossRef (polite pool — set your real email)
CROSSREF_USER_AGENT=KIMY/0.1 (mailto:contact@example.com)

# Storage
STORAGE_BACKEND=local
STORAGE_PATH=./storage
